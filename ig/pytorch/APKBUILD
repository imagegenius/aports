# Maintainer: hydaz <ci@imagegenius.io>

pkgname=pytorch
pkgver=1.13.1
pkgrel=0
pkgdesc="A deep learning framework for fast, flexible experimentation."
url="https://pytorch.org/"
arch="all"
license="BSD-3-Clause"
depends=""
makedepends="gcc g++ git make cmake python3-dev py3-setuptools py3-wheel openblas-dev"
source="https://github.com/pytorch/pytorch/archive/v${pkgver}.tar.gz"

build() {
	cd "$srcdir/$pkgname-$pkgver"
	export CMAKE_PREFIX_PATH=/usr/lib/cmake/openblas:$CMAKE_PREFIX_PATH
	python3 setup.py build
}

package() {
	cd "$srcdir/$pkgname-$pkgver"
	python3 setup.py install --root="$pkgdir/" --optimize=1
}

sha512sums="f16f89d027efade11d057245cad5b69a390e88b458398310ae30de2dbff7c8fd7f1165be7b8da7ea989c81ac3f5a66c5cb9050610e441a97c83fb8aa28c0bd62  v1.13.1.tar.gz"
